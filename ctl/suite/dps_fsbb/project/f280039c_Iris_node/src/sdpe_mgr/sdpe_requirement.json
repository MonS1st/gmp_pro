{
  "id": "dps_fsbb_f280039c_Iris_node",
  "display_name": "DPS FSBB F280039C IRIS Node",
  "suite": "dps_fsbb",
  "version": "0.1.0",
  "output_header": "sdpe_dps_fsbb_iris_settings.h",
  "hardware": [
    {
      "entity": "iris_f280039c_node"
    },
    {
      "entity": "gmp_lvfb_150_2ph_v2"
    },
    {
      "entity": "quad_sensor_voltage_channel"
    }
  ],
  "requirements": [
    {
      "role": "PWM Frequency",
      "macro": "PWM_FREQ",
      "binding": {
        "float": "20e3"
      },
      "description": "PWM carrier frequency used by the FSBB power stage."
    },
    {
      "role": "Controller Frequency",
      "macro": "CONTROLLER_FREQUENCY",
      "binding": {
        "float": "20e3"
      },
      "description": "Main control ISR frequency."
    },
    {
      "role": "PWM Depth",
      "macro": "CTRL_PWM_CMP_MAX",
      "binding": {
        "number": "3000 - 1"
      },
      "description": "PWM compare maximum value for the configured ePWM time base."
    },
    {
      "role": "PWM Deadband Width",
      "macro": "CTRL_PWM_DEADBAND_CMP",
      "binding": {
        "number": "50"
      },
      "description": "PWM deadband compare count."
    },
    {
      "role": "CPU Main Frequency",
      "macro": "CTRL_SYS_FREQUENCY",
      "binding": {
        "number": "120e6"
      },
      "description": "CPU main clock frequency."
    },
    {
      "role": "System Divition",
      "macro": "DSP_C2000_DSP_TIME_DIV",
      "binding": {
        "number": "CTRL_SYS_FREQUENCY / 1000 / CTRL_PWM_CMP_MAX / 2"
      },
      "description": "C2000 system tick divider derived from PWM period."
    },
    {
      "role": "ADC reference Voltage",
      "macro": "CTRL_ADC_VOLTAGE_REF",
      "binding": {
        "float": "3.3"
      },
      "description": "ADC voltage reference used by sensor gain and bias conversion."
    },
    {
      "role": "ADC Resolution",
      "macro": "CTRL_ADC_RESOLUTION",
      "binding": {
        "number": "12"
      },
      "description": "F280039C ADC resolution used by the shared sensor conversion and compile-test platform."
    },
    {
      "role": "Voltage PU Base",
      "macro": "CTRL_VOLTAGE_BASE",
      "binding": {
        "float": "34.0"
      },
      "description": "Voltage per-unit base value, using the peak value of the nominal 24 Vrms system."
    },
    {
      "role": "Current PU Base",
      "macro": "CTRL_CURRENT_BASE",
      "binding": {
        "float": "14.14"
      },
      "description": "Current per-unit base value, using the peak value of the nominal 10 Arms system."
    },
    {
      "role": "Input Voltage Sensitive",
      "macro": "CTRL_FSBB_VIN_SENSITIVITY",
      "binding": {
        "export": "gmp_lvfb_150_2ph_v2.voltage_sensitivity"
      },
      "description": "Input voltage ADC sensing sensitivity provided by the LVFB voltage sensor path."
    },
    {
      "role": "Input Voltage Bias",
      "macro": "CTRL_FSBB_VIN_BIAS",
      "binding": {
        "export": "gmp_lvfb_150_2ph_v2.voltage_bias_v"
      },
      "description": "Input voltage ADC bias voltage provided by the LVFB voltage sensor path."
    },
    {
      "role": "Output Voltage Sensor Polarity",
      "macro": "FSBB_VOUT_SENSOR_POLARITY",
      "binding": {
        "number": "1"
      },
      "description": "Provisional polarity sign (+1 or -1). This is not a hardware verification; uncalibrated use is allowed only by the explicit FSBB_BUILD4_NOMINAL_SENSOR_BRINGUP exception."
    },
    {
      "role": "Output Voltage Sensor Bias",
      "macro": "FSBB_VOUT_SENSOR_BIAS_V",
      "binding": {
        "export": "quad_sensor_voltage_channel.bias"
      },
      "description": "Nominal QuadSensor bias placeholder in volts; replace with measured calibration data before setting FSBB_VOUT_SENSOR_CALIBRATED to 1."
    },
    {
      "role": "Output Voltage Sensor Sensitivity",
      "macro": "FSBB_VOUT_SENSOR_SENSITIVITY",
      "binding": {
        "export": "quad_sensor_voltage_channel.sensitivity"
      },
      "description": "Nominal QuadSensor sensitivity placeholder in V/V; it is not an actual Iris hardware calibration result."
    },
    {
      "role": "Output Voltage Sensor Calibrated",
      "macro": "FSBB_VOUT_SENSOR_CALIBRATED",
      "binding": {
        "number": "0"
      },
      "description": "Set to 1 only after the physical Vout channel bias, sensitivity, and polarity have been measured."
    },
    {
      "role": "Output Voltage Sensitive Compatibility",
      "macro": "CTRL_FSBB_VOUT_SENSITIVITY",
      "binding": {
        "number": "FSBB_VOUT_SENSOR_SENSITIVITY"
      },
      "description": "Compatibility alias used by the existing adc_channel conversion path."
    },
    {
      "role": "Output Voltage Bias Compatibility",
      "macro": "CTRL_FSBB_VOUT_BIAS",
      "binding": {
        "number": "FSBB_VOUT_SENSOR_BIAS_V"
      },
      "description": "Compatibility alias used by the existing adc_channel conversion path."
    },
    {
      "role": "Inductor Current Sensitive",
      "macro": "CTRL_FSBB_IL_SENSITIVITY",
      "binding": {
        "export": "gmp_lvfb_150_2ph_v2.current_sensitivity"
      },
      "description": "Inductor current ADC sensing sensitivity provided by the LVFB current sensor path."
    },
    {
      "role": "Inductor Current Bias",
      "macro": "CTRL_FSBB_IL_BIAS",
      "binding": {
        "export": "gmp_lvfb_150_2ph_v2.current_bias_v"
      },
      "description": "Inductor current ADC bias voltage provided by the LVFB current sensor path."
    },
    {
      "role": "Output Current Sensor Polarity",
      "macro": "FSBB_IOUT_SENSOR_POLARITY",
      "binding": {
        "number": "1"
      },
      "description": "Provisional polarity sign (+1 or -1). This is not a hardware verification; uncalibrated use is allowed only by the explicit FSBB_BUILD4_NOMINAL_SENSOR_BRINGUP exception."
    },
    {
      "role": "Output Current Sensor Bias",
      "macro": "FSBB_IOUT_SENSOR_BIAS_V",
      "binding": {
        "export": "gmp_lvfb_150_2ph_v2.current_bias_v"
      },
      "description": "Existing LVFB nominal current-sensor bias placeholder in volts; replace with the measured Iout channel calibration."
    },
    {
      "role": "Output Current Sensor Sensitivity",
      "macro": "FSBB_IOUT_SENSOR_SENSITIVITY",
      "binding": {
        "export": "gmp_lvfb_150_2ph_v2.current_sensitivity"
      },
      "description": "Existing LVFB nominal sensitivity placeholder in V/A; it is not an actual Iout channel calibration result."
    },
    {
      "role": "Output Current Sensor Calibrated",
      "macro": "FSBB_IOUT_SENSOR_CALIBRATED",
      "binding": {
        "number": "0"
      },
      "description": "Set to 1 only after the physical Iout channel bias, sensitivity, and polarity have been measured."
    },
    {
      "role": "Output Current Sensitive Compatibility",
      "macro": "CTRL_FSBB_IOUT_SENSITIVITY",
      "binding": {
        "number": "FSBB_IOUT_SENSOR_SENSITIVITY"
      },
      "description": "Compatibility alias used by the existing adc_channel conversion path."
    },
    {
      "role": "Output Current Bias Compatibility",
      "macro": "CTRL_FSBB_IOUT_BIAS",
      "binding": {
        "number": "FSBB_IOUT_SENSOR_BIAS_V"
      },
      "description": "Compatibility alias used by the existing adc_channel conversion path."
    },
    {
      "role": "Min Resistance Load",
      "macro": "FSBB_PARAM_RLOAD_MIN",
      "binding": {
        "float": "20.0"
      },
      "description": "Minimum load resistance used by FSBB controller initialization."
    },
    {
      "role": "Input Capcitor",
      "macro": "FSBB_PARAM_CIN",
      "binding": {
        "float": "440e-6"
      },
      "description": "Input DC-link capacitance."
    },
    {
      "role": "Output Capcitor",
      "macro": "FSBB_PARAM_COUT",
      "binding": {
        "float": "440e-6"
      },
      "description": "Output capacitance used by FSBB controller initialization."
    },
    {
      "role": "ESR of Output Capcitor",
      "macro": "FSBB_PARAM_COUT_ESR",
      "binding": {
        "float": "0.1"
      },
      "description": "Output capacitor equivalent series resistance."
    },
    {
      "role": "Main Inductor",
      "macro": "FSBB_PARAM_L",
      "binding": {
        "float": "1.5e-3"
      },
      "description": "Main FSBB inductor value."
    },
    {
      "role": "ESR of Main Inductor",
      "macro": "FSBB_PARAM_L_ESR",
      "binding": {
        "float": "0.05"
      },
      "description": "Main inductor equivalent series resistance."
    },
    {
      "role": "Max Input Voltage",
      "macro": "FSBB_INPUT_VOLTAGE_MAX",
      "binding": {
        "float": "60.0"
      },
      "description": ""
    },
    {
      "role": "Min Input Voltage",
      "macro": "FSBB_INPUT_VOLTAGE_MIN",
      "binding": {
        "float": "12.0"
      },
      "description": "Minimum allowed FSBB input voltage."
    },
    {
      "role": "Nominal Input Voltage",
      "macro": "FSBB_INPUT_VOLTAGE_NOMINAL",
      "binding": {
        "float": "12.0"
      },
      "description": "Nominal input voltage used when input-voltage sampling is disabled."
    },
    {
      "role": "Max Output Voltage",
      "macro": "FSBB_OUTPUT_VOLTAGE_MAX",
      "binding": {
        "float": "72.0"
      },
      "description": "Maximum allowed FSBB output voltage command."
    },
    {
      "role": "Min Output Voltage",
      "macro": "FSBB_OUTPUT_VOLTAGE_MIN",
      "binding": {
        "float": "3.0"
      },
      "description": "Minimum allowed FSBB output voltage command."
    },
    {
      "role": "Max Output Current",
      "macro": "FSBB_OUTPUT_CURRENT_LIM",
      "binding": {
        "float": "10.0"
      },
      "description": "Maximum allowed FSBB output/load current."
    },
    {
      "role": "Default Output Voltage",
      "macro": "FSBB_DEFAULT_OUTPUT_VOLTAGE",
      "binding": {
        "float": "5.0"
      },
      "description": "Conservative first-hardware startup output-voltage command."
    },
    {
      "role": "Default Current Limit",
      "macro": "FSBB_DEFAULT_CURRENT_LIMIT",
      "binding": {
        "float": "0.2"
      },
      "description": "Conservative first-hardware startup current command and user limit."
    },
    {
      "role": "Open Loop Voltage Command",
      "macro": "FSBB_OPEN_LOOP_VOLTAGE_COMMAND",
      "binding": {
        "float": "12.0"
      },
      "description": "Equivalent output-voltage command used by BUILD_LEVEL 1."
    },
    {
      "role": "Voltage Ramp Rate",
      "macro": "FSBB_VOLTAGE_RAMP_PU_S",
      "binding": {
        "float": "1.0"
      },
      "description": "Voltage-reference slew rate in PU/s."
    },
    {
      "role": "Current Ramp Rate",
      "macro": "FSBB_CURRENT_RAMP_PU_S",
      "binding": {
        "float": "1.0"
      },
      "description": "Current-reference slew rate in PU/s."
    },
    {
      "role": "Current Loop Bandwidth",
      "macro": "FSBB_CURRENT_LOOP_BANDWIDTH",
      "binding": {
        "float": "800.0"
      },
      "description": "Requested current-loop crossover frequency."
    },
    {
      "role": "Voltage Loop Bandwidth",
      "macro": "FSBB_VOLTAGE_LOOP_BANDWIDTH",
      "binding": {
        "float": "10.0"
      },
      "description": "Conservative 10 Hz first-hardware voltage-loop crossover; chosen well below the 150 Hz Vout feedback filter cutoff."
    },
    {
      "role": "Maximum Inductor Current Reference",
      "macro": "FSBB_INDUCTOR_CURRENT_REF_MAX",
      "binding": {
        "float": "0.3"
      },
      "description": "Maximum Build 4 inductor-current command for conservative first-hardware operation."
    },
    {
      "role": "CV CC Switching Hysteresis",
      "macro": "FSBB_CVCC_SWITCH_HYSTERESIS",
      "binding": {
        "float": "0.02"
      },
      "description": "CV/CC candidate-selection hysteresis in amperes."
    },
    {
      "role": "Output Current Outer-loop Kp",
      "macro": "FSBB_OUTPUT_CURRENT_LOOP_KP",
      "binding": {
        "float": "0.2"
      },
      "description": "Conservative proportional gain for the Build 4 output-current outer loop."
    },
    {
      "role": "Output Current Outer-loop Ti",
      "macro": "FSBB_OUTPUT_CURRENT_LOOP_TI",
      "binding": {
        "float": "0.05"
      },
      "description": "Conservative Build 4 output-current outer-loop integral time in seconds."
    },
    {
      "role": "Build 4 Self Test Enable",
      "macro": "FSBB_BUILD4_SELF_TEST_ENABLE",
      "binding": {
        "number": "0"
      },
      "description": "Must remain 0 on Iris hardware; compile-time validation rejects fault-injection self test."
    },
    {
      "role": "Build 4 Nominal Sensor Bringup",
      "macro": "FSBB_BUILD4_NOMINAL_SENSOR_BRINGUP",
      "binding": {
        "number": "1"
      },
      "description": "Explicit first-low-voltage hardware bring-up exception. Allows Build 4 to use the uncalibrated QuadSensor Vout and LVFB Iout nominal coefficients; this is not formal sensor calibration."
    },
    {
      "role": "Vout Filter Enable",
      "macro": "FSBB_VOUT_FILTER_ENABLE",
      "binding": {
        "number": "1"
      },
      "description": "Enable the existing dcdc_core first-order IIR only on the voltage-loop Vout feedback path."
    },
    {
      "role": "Vout Filter Parameter",
      "macro": "FSBB_VOUT_FILTER_PARAMETER",
      "binding": {
        "float": "150.0"
      },
      "description": "First-order IIR Vout cutoff frequency in hertz; filtering suppresses noise but cannot recover ADC resolution."
    },
    {
      "role": "Hardware Sensor Calibration Mode",
      "macro": "FSBB_HARDWARE_SENSOR_CALIBRATION_MODE",
      "binding": {
        "number": "0"
      },
      "description": "Set to 1 only with BUILD_LEVEL 1 to keep PWM tripped while sampling and exporting sensor calibration data."
    },
    {
      "role": "Vin Protection Debounce Samples",
      "macro": "FSBB_VIN_PROTECTION_DEBOUNCE_SAMPLES",
      "binding": {
        "number": "200"
      },
      "description": "Consecutive valid Vin samples required before latching UV/OV faults (10 ms at 20 kHz)."
    },
    {
      "role": "Maximum Duty",
      "macro": "FSBB_DUTY_MAX",
      "binding": {
        "float": "0.95"
      },
      "description": "Maximum FSBB leg duty ratio."
    },
    {
      "role": "Minimum Duty",
      "macro": "FSBB_DUTY_MIN",
      "binding": {
        "float": "0.05"
      },
      "description": "Minimum FSBB leg duty ratio."
    },
    {
      "role": "Low Transition Ratio",
      "macro": "FSBB_TRANSITION_RATIO_LOW",
      "binding": {
        "float": "0.90"
      },
      "description": "Lower voltage-ratio boundary of the buck-boost transition region."
    },
    {
      "role": "High Transition Ratio",
      "macro": "FSBB_TRANSITION_RATIO_HIGH",
      "binding": {
        "float": "1.10"
      },
      "description": "Upper voltage-ratio boundary of the buck-boost transition region."
    },
    {
      "role": "Max Inductor Current",
      "macro": "FSBB_PROTECT_IL_MAX",
      "binding": {
        "float": "25.0"
      },
      "description": "Positive inductor current protection threshold."
    },
    {
      "role": "Min Inductor Current",
      "macro": "FSBB_PROTECT_IL_MIN",
      "binding": {
        "float": "-2.0"
      },
      "description": "Negative inductor current protection threshold."
    },
    {
      "role": "adc_calibration_timeout",
      "macro": "TIMEOUT_ADC_CALIB_MS",
      "binding": {
        "number": "3000"
      },
      "description": "ADC calibration timeout in ms."
    },
    {
      "role": "spll_epsilon",
      "macro": "CTRL_SPLL_EPSILON",
      "binding": {
        "literal": "((float2ctrl(0.005)))"
      },
      "description": "SPLL close-loop convergence threshold."
    }
  ],
  "feature_macros": [
    {
      "group": "Controller Settings",
      "macro": "SPECIFY_ENABLE_ADC_CALIBRATE",
      "enabled": true,
      "value": "",
      "description": "Enable ADC calibration before normal control starts."
    },
    {
      "group": "Controller Settings",
      "macro": "ENABLE_GMP_DL_PIL_SIM",
      "enabled": false,
      "value": "",
      "description": "Enable PIL simulation mode. This mode disables direct controller output for safe communication-based simulation."
    },
    {
      "group": "Controller Settings",
      "macro": "GMP_CTL_FM_CONFIG_ENABLE_DEBUG_INFO",
      "enabled": false,
      "value": "",
      "description": "Enable GMP framework debug information."
    },
    {
      "group": "Controller Settings",
      "macro": "PWM_MODULATOR_USING_NEGATIVE_LOGIC",
      "enabled": true,
      "value": "1",
      "description": "Invert duty-to-CMP mapping because the IRIS ePWM action qualifier sets high on up-count CMPA and low on down-count CMPA."
    },
    {
      "group": "Optional Sampling Channels",
      "macro": "FSBB_ENABLE_IOUT_SAMPLE",
      "enabled": true,
      "value": "",
      "description": "Enable output/load current sampling path."
    },
    {
      "group": "Optional Sampling Channels",
      "macro": "FSBB_ENABLE_VIN_SAMPLE",
      "enabled": false,
      "value": "",
      "description": "Enable input voltage sampling path."
    }
  ],
